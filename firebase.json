{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "database.rules.json",
      "*.log",
      ".firebaserc"
    ],
    "rewrites": [
      {
        "source": "/portfolio/:code",
        "destination": "/portfolio-view.html"
      },
      {
        "source": "/p/:code",
        "destination": "/portfolio-view.html"
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
