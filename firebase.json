{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/portfolio/:code",
        "destination": "/portfolio-view.html"
      },
      {
        "source": "/p/:code",
        "destination": "/p.html"
      }
    ]
  }
}
